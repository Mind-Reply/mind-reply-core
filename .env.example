# Core runtime
NODE_ENV=development
PORT=3000
DATABASE_URL=

# Public app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Authentication (REQUIRED - no defaults, must be set)
ADMIN_PASSWORD=
ADMIN_TOKEN_SECRET=
JWT_SECRET=

# OpenAI
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-2

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Anthropic
ANTHROPIC_API_KEY=

# Google integrations
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Observability
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Optional deployment support
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
