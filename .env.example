# Environment Variables for MindReply
# Copy to .env and fill in real secrets for production.
# Never commit .env files. Only .env.example is tracked.

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/mindreply
DB_PASSWORD=

# Frontend
NODE_ENV=production
PORT=3000

# Backend Services
OPENAI_API_KEY=
SUPABASE_URL=
SUPABASE_KEY=

# N8N
N8N_WEBHOOK_URL=

# Salesforce
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_INSTANCE_URL=

# Security
JWT_SECRET=
CORS_ORIGIN=https://mind-reply.com

# Redis
REDIS_HOST=
REDIS_PORT=6379

# MCP Server
MCP_PORT=3001

# Anthropic
ANTHROPIC_API_KEY=

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Vercel Blob
BLOB_READ_WRITE_TOKEN=
